#!/usr/bin/env bash
# Enforces commit message format for the coordination root.
# Also applies the cross-repo banned-word policy.
#
# Format rules (same as subprojects):
#   Human: <type>(<scope>): <subject>
#   AI:    🤖 <type>(<scope>): <subject>
# Allowed types: feat|fix|chore|docs|refactor|ci
# Merge/revert commits bypass format checks (not banned-word check).
# Subject: max 72 chars. Body: max 10 lines, wrap at 72.

COMMIT_MSG_FILE="$1"
MSG=$(head -1 "$COMMIT_MSG_FILE")

TYPES="feat|fix|chore|docs|refactor|ci"
MAX_LEN=72

# Banned words — no AI attribution anywhere in commit messages
if grep -qiE 'Co-Authored-By|Claude|anthropic|Sonnet|Opus' "$COMMIT_MSG_FILE"; then
  MATCHED=$(grep -iE 'Co-Authored-By|Claude|anthropic|Sonnet|Opus' "$COMMIT_MSG_FILE" | head -3)
  echo ""
  echo "  BANNED WORD IN COMMIT MESSAGE"
  echo ""
  echo "  Commit messages must not contain:"
  echo "    Co-Authored-By · Claude · anthropic · Sonnet · Opus"
  echo "  Matched:"
  echo "$MATCHED" | sed 's/^/    /'
  echo ""
  exit 1
fi

# Allow git-generated merge and revert commits
if echo "$MSG" | grep -qE "^(Merge |Revert )"; then
  exit 0
fi

# Enforce subject line length limit
if [ "${#MSG}" -gt "$MAX_LEN" ]; then
  echo ""
  echo "  COMMIT MESSAGE TOO LONG"
  echo ""
  echo "  Subject line is ${#MSG} characters (max $MAX_LEN)."
  echo "  Got: $MSG"
  echo ""
  exit 1
fi

# Enforce body limits: max lines and max width.
# Excluded: blank lines, comment lines (#), trailers (Key: value),
# lines with no whitespace (URLs, long identifiers).
MAX_BODY_LINES=10
BODY_LINES=$(tail -n +2 "$COMMIT_MSG_FILE" \
  | grep -vE '^\s*$' \
  | grep -vE '^#' \
  | grep -vE '^[A-Za-z-]+: ' || true)

if [ -n "$BODY_LINES" ]; then
  BODY_COUNT=$(echo "$BODY_LINES" | wc -l)
  if [ "$BODY_COUNT" -gt "$MAX_BODY_LINES" ]; then
    echo ""
    echo "  COMMIT BODY TOO LONG"
    echo ""
    echo "  Body is $BODY_COUNT lines (max $MAX_BODY_LINES, excluding blanks/trailers)."
    echo "  Keep the body terse: what changed and why. Detail belongs in"
    echo "  PR descriptions or docs, not the commit message."
    echo ""
    exit 1
  fi
  WIDE_LINE=$(echo "$BODY_LINES" | grep -E '\s' | awk -v max="$MAX_LEN" 'length($0) > max { print; exit }')
  if [ -n "$WIDE_LINE" ]; then
    echo ""
    echo "  COMMIT BODY LINE TOO WIDE"
    echo ""
    echo "  Wrap body lines at $MAX_LEN characters."
    echo "  Got: $WIDE_LINE"
    echo ""
    exit 1
  fi
fi

# Allow human format:  <type>(<scope>): <subject>
# Allow AI format:     🤖 <type>(<scope>): <subject>
if echo "$MSG" | grep -qE "^(🤖 )?($TYPES)(\(.+\))?: .+"; then
  exit 0
fi

echo ""
echo "  INVALID COMMIT MESSAGE"
echo ""
echo "  Got:      $MSG"
echo ""
echo "  Expected:"
echo "    Human:  <type>(<scope>): <subject>"
echo "    AI:     🤖 <type>(<scope>): <subject>"
echo ""
echo "  Types: feat | fix | chore | docs | refactor | ci"
echo "  Scope: optional, e.g. feat(auth): ..."
echo ""
echo "  Examples:"
echo "    docs: update COMPATIBILITY.md"
echo "    🤖 chore: merge docs/audit-2026-06-12"
echo ""
exit 1
