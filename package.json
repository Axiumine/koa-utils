{
	"name": "@axiumine/koa-utils",
	"version": "4.0.0",
	"description": "Koa Utils",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/Axiumine/koa-utils"
	},
	"license": "GPL-3.0-or-later",
	"author": "Giovanni Manzoni <dev@giovannimanzoni.com> (https://www.giovannimanzoni.com)",
	"private": false,
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"prepare": "yarn run hooks:install && rm -rf dist && yarn run build",
		"hooks:install": "git rev-parse --git-dir > /dev/null 2>&1 && git config core.hooksPath .githooks || true",
		"build": "yarn clean && yarn run build:esm",
		"prepare:all": "echo 'read REAMDE' && rm -rf dist && yarn run build:all",
		"build:all": "yarn run build:cjs && yarn run build:esm",
		"build:cjs": "yarn run tsc -p tsconfig.cjs.json && find dist/cjs -type f -name \"*.js\" -exec bash -c 'mv \"$0\" \"${0%.js}.cjs\"' {} \\; && cp -R dist/cjs/* dist/ && rm -rf dist/cjs",
		"build:esm": "yarn run tspc -p tsconfig.json && find dist/esm -type f -name \"*.js\" -exec bash -c 'mv \"$0\" \"${0%.js}.mjs\"' {} \\; && cp -R dist/esm/* dist/ && find dist -name \"*.mjs.map\" -exec sed -i -E 's#(\"sources\":\\[\")\\.\\./#\\1#' {} + && rm -rf dist/esm",
		"lint": "eslint --fix && prettier --write 'src/**/*.mts'",
		"clean": "rm -rf ./dist",
		"build:tests": "rm -rf dist-test && yarn run tspc -p tsconfig.build-tests.json && find dist-test -type f -name \"*.js\" -exec bash -c 'mv \"$0\" \"${0%.js}.mjs\"' {} \\;",
		"test": "yarn build && yarn build:tests && mocha",
		"test:watch": "mocha --watch",
		"test:coverage": "yarn build && yarn build:tests && c8 mocha",
		"qodana": "yarn test:coverage && mkdir -p .qodana/results && docker run --rm --env-file .env -v \"$PWD\":/data/project -v \"$PWD\"/.qodana/results:/data/results jetbrains/qodana-js:2026.1 --show-report",
		"qodana:cli": "yarn test:coverage && set -a && . ./.env && set +a && qodana scan --show-report",
		"semgrep": "./scripts/semgrep.sh",
		"semgrep:all": "./scripts/semgrep.sh --registry",
		"semgrep:canary": "./scripts/semgrep-canary.sh",
		"upload": "npm publish",
		"update": "yarn upgrade-interactive --latest --network-timeout 100000",
		"cloc": "cloc . --exclude-dir=node_modules,dist,.git,upload",
		"scc": "scc . --exclude-dir=node_modules,dist,.git -w --sort --directory-walker-job-workers=8 --count-as=mts:TypeScript"
	},
	"engines": {
		"node": "^24.14.0"
	},
